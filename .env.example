# Provedor LLM ativo: openai (default) ou anthropic
LLM_PROVIDER=openai

# Necessario quando LLM_PROVIDER=openai
OPENAI_API_KEY=

# Necessario quando LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Mongo local via docker compose:
#   MONGODB_URI=mongodb://curio:curio@localhost:27017/curio?authSource=admin
# Ou Atlas: mongodb+srv://...
MONGODB_URI=
MONGODB_DB_NAME=curio
